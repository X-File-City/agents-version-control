/**
 * GitHub for Agents — control plane Worker.
 * Local setup notes live in README and migration files in this repo.
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "github-for-agents",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-23",
	"compatibility_flags": ["nodejs_compat"],
	"observability": { "enabled": true },
	"upload_source_maps": true,

	"durable_objects": {
		"bindings": [
			{ "name": "MCP_OBJECT", "class_name": "AgentsMcpServer" },
			{ "name": "SANDBOX", "class_name": "Sandbox" },
			{ "name": "REPO_OBJECT", "class_name": "RepoDO" }
		]
	},

	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["AgentsMcpServer", "Sandbox"]
		},
		{
			"tag": "v2",
			"new_sqlite_classes": ["RepoDO"]
		}
	],

	"containers": [
		{
			"class_name": "Sandbox",
			"image": "./Dockerfile",
			"instance_type": "lite",
			"max_instances": 2
		}
	],

	"d1_databases": [
		{ "binding": "DB", "database_name": "github-for-agents-db", "database_id": "340f47cc-1ada-4b19-9499-71df90065faf" }
	],

	"kv_namespaces": [
		{ "binding": "OAUTH_KV", "id": "381b72106fcb41e3be6523782b681586" }
	],

	"artifacts": [
		{ "binding": "ARTIFACTS", "namespace": "github-for-agents" }
	]
}
